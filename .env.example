# Copy to .env and fill in values. Restart `npm run dev` after changes.

# OpenAI (existing)
VITE_OPENAI_API_KEY=sk-proj-your-key-here

# Supabase (optional — app keeps using localStorage until enabled)
# 1) Create project at https://supabase.com
# 2) Run SQL from supabase/schema.sql in SQL Editor
# 3) Project Settings → API → copy URL + anon key
# 4) Set VITE_USE_SUPABASE=true
VITE_USE_SUPABASE=false
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
