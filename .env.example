# Copy to .env and fill in values. Restart `npm run dev` after changes.

# OpenAI (required for AI features)
VITE_OPENAI_API_KEY=sk-proj-your-key-here

# Supabase (recommended for jury demo — cloud sync)
# 1) Create project at https://supabase.com
# 2) Run SQL in order:
#      supabase/schema.sql
#      supabase/schema_auth.sql
#      supabase/schema_gamification.sql
#      supabase/schema_learning.sql
# 3) Auth → Email → disable "Confirm email"
# 4) Project Settings → API → copy URL + anon key
# 5) Set VITE_USE_SUPABASE=true
VITE_USE_SUPABASE=false
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
